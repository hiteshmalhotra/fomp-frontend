# FOMP frontend environment template — copy to .env.development / .env.production
# All variables must be prefixed VITE_ to be exposed to the client.

# API Gateway base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:8080

# Branding
VITE_APP_NAME=Food Operations Management Platform
VITE_APP_SHORT_NAME=FOMP

# Environment name: development | production
VITE_ENV=development
